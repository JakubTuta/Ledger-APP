# ==================== Environment ====================
ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ==================== Auth Database ====================
AUTH_DB_HOST=ledger-postgres
AUTH_DB_PORT=5432
AUTH_DB_NAME=auth_db
AUTH_DB_USER=postgres
AUTH_DB_PASSWORD=postgres

# ==================== Logs Database ====================
LOGS_DB_HOST=ledger-postgres-logs
LOGS_DB_PORT=5432
LOGS_DB_NAME=logs_db
LOGS_DB_USER=postgres
LOGS_DB_PASSWORD=postgres

# ==================== Redis ====================
REDIS_HOST=ledger-redis
REDIS_PORT=6379
REDIS_PASSWORD=password

# ==================== RabbitMQ ====================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=ledger
RABBITMQ_PASSWORD=ledger

# ==================== Service Discovery (Gateway -> internal gRPC services) ====================
AUTH_SERVICE_HOST=ledger-auth-service
INGESTION_SERVICE_HOST=ledger-ingestion
QUERY_SERVICE_HOST=ledger-query

# ==================== Gateway Service ====================
GATEWAY_HTTP_PORT=8020
GATEWAY_WORKERS=4

# ==================== Security ====================
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_use_openssl_rand_hex_32

# ==================== Frontend / Email ====================
FRONTEND_URL=http://localhost:3020

# ==================== Email Alerts (SMTP) ====================
EMAIL_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=alerts@yourdomain.com
SMTP_PASSWORD=your-mailbox-password
SMTP_FROM=alerts@yourdomain.com

# ==================== Feature Flags ====================
NOTIFICATIONS_ENABLED=true
ENABLE_PARTITION_SCHEDULER=true
ALERT_WEBHOOK_ALLOW_HTTP=false

# ==================== Analytics cron overrides (optional) ====================
# All analytics job schedules are constants in
# services/analytics/analytics_workers/config.py with tuned production
# defaults. Uncomment and set any of these only if you need a different
# schedule than the built-in default for your deployment.
# ANALYTICS_LOG_METRICS_CRON=*/10 * * * *
# ANALYTICS_TOP_ERRORS_CRON=*/30 * * * *
# ANALYTICS_USAGE_STATS_CRON=*/10 * * * *
# ANALYTICS_HOURLY_METRICS_CRON=0 * * * *
# ANALYTICS_AVAILABLE_ROUTES_CRON=0 */2 * * *
# ANALYTICS_BOTTLENECK_METRICS_CRON=30 * * * *
# ANALYTICS_LOG_VOLUME_1H_ROLLUP_CRON=*/10 * * * *
# ANALYTICS_LOG_VOLUME_1D_ROLLUP_CRON=5 * * * *
# ANALYTICS_PARTITION_MANAGER_CRON=10 * * * *
# ANALYTICS_SPAN_LATENCY_1H_CRON=*/5 * * * *
# ANALYTICS_METRIC_POINTS_1H_ROLLUP_CRON=*/10 * * * *
# ANALYTICS_ALERT_EVALUATOR_CRON=*/1 * * * *
# ANALYTICS_MONITOR_CHECK_CRON=*/1 * * * *
# ANALYTICS_ERROR_REGRESSION_CRON=*/5 * * * *
# ANALYTICS_NOTIFICATION_CLEANUP_CRON=0 3 * * *
# ANALYTICS_RETENTION_CRON=0 3 * * *
